{
	"schemaVersion": 1,
	"id": "glaze",
	"version": "${version}",
	"name": "Glaze",
	"description": "This is a QOL mod for the DonutSMP Minecraft server!",
	"authors": [
		"RubyImpala"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "GPL-3.0-or-later",
	"icon": "assets/glaze/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.rubyimpala.Glaze"
		],
		"client": [
			"com.rubyimpala.GlazeClient"
		],
		"fabric-datagen": [
			"com.rubyimpala.GlazeDataGenerator"
		]
	},
	"mixins": [
		"glaze.mixins.json",
		{
			"config": "glaze.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}